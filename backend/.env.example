# Application
APP_NAME=HourHive
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/hourhive
DB_ECHO=false

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (FastAPI-Mail)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@gnxtsystems.com
MAIL_FROM_NAME=HourHive - gNxt Systems
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# Frontend URL (for reset links)
FRONTEND_URL=http://localhost:5173

# Defaults (overridden per tenant via system_config table)
DEFAULT_BACKDATED_DAYS_LIMIT=7
DEFAULT_MAX_DAILY_HOURS=12
